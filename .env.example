# =========================================================================
# Firebase Configuration
# =========================================================================
# NOTE: To run this project locally, create a copy of this file, 
# rename it to '.env', and populate the placeholders with your actual 
# Firebase project credentials.
# You can find these details in: Firebase Console -> Project Settings -> General

VITE_FIREBASE_API_KEY="your_firebase_api_key_here"
VITE_FIREBASE_AUTH_DOMAIN="your-project-id.firebaseapp.com"
VITE_FIREBASE_DATABASE_URL="https://your-project-id-default-rtdb.europe-west1.firebasedatabase.app/"
VITE_FIREBASE_PROJECT_ID="your_project_id_here"
VITE_FIREBASE_STORAGE_BUCKET="your-project-id.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="your_messaging_sender_id_here"
VITE_FIREBASE_APP_ID="1:1234567890:web:abcdef1234567890"
VITE_FIREBASE_MEASUREMENT_ID="G-YOURMEASUREMENTID"
VITE_FIREBASE_DB_ROOT="https://your-project-id-default-rtdb.europe-west1.firebasedatabase.app/"